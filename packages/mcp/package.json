{
  "name": "tasksync-mcp",
  "version": "1.0.12",
  "description": "TaskSync MCP server for iterative human feedback loops",
  "license": "MIT",
  "author": "TaskSync",
  "type": "module",
  "bin": {
    "tasksync-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",

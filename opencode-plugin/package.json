{
  "name": "opencode-tasksync",
  "version": "1.4.3",
  "description": "OpenCode plugin for TaskSync — persistent daemon feedback loop for AI coding agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "tasksync",
    "feedback",
    "daemon",
    "agent",
    "human-in-the-loop"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vikrant82/tasksync-mcp.git",
    "directory": "opencode-plugin"
  },
  "homepage": "https://github.com/vikrant82/tasksync-mcp/tree/main/opencode-plugin",
  "bugs": {
    "url": "https://github.com/vikrant82/tasksync-mcp/issues"
  },
  "author": "vikrant82",
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "^1.3.3",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.8.2"
  }
}

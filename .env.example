# TaskSync MCP Server Configuration
# Copy this file to .env and fill in your values

# ── Server ──────────────────────────────────────────────────
# Port for the feedback UI and REST API (default: 3456)
# FEEDBACK_PORT=3456

# Log level: debug | info | warn | error (default: info)
# TASKSYNC_LOG_LEVEL=info

# Path to a log file (optional — logs to file in addition to stdout)
# TASKSYNC_LOG_FILE=

# ── Telegram (Remote Mode) ─────────────────────────────────
# Bot token from @BotFather (optional — enables remote mode notifications)
# NOTE: Each TaskSync server needs its own bot — Telegram only allows one polling connection per token
# TASKSYNC_TELEGRAM_BOT_TOKEN=

# Restrict Telegram bot to specific chat IDs (optional, comma-separated)
# TASKSYNC_TELEGRAM_CHAT_IDS=

# ── OpenCode Plugin ────────────────────────────────────────
# Override the TaskSync server URL the plugin connects to (default: http://localhost:3011)
# TASKSYNC_SERVER_URL=http://localhost:3011

# Augment agent system prompts with feedback-loop overlay (default: true)
# TASKSYNC_AUGMENT_AGENTS=true

# Overlay injection style: append | prepend (default: append)
# TASKSYNC_OVERLAY_STYLE=append

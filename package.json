{
  "private": true,
  "name": "tasksync",
  "version": "1.0.0",
  "description": "TaskSync: iterative human feedback loops for coding agents",
  "license": "MIT",
  "author": "TaskSync",
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/mcp",
    "packages/opencode-plugin"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:core": "npm run build -w packages/core",
    "build:mcp": "npm run build -w packages/mcp",
    "build:plugin": "npm run build -w packages/opencode-plugin",
    "watch": "npm run watch --workspaces --if-present",
    "test": "jest --config=jest.config.cjs --coverage",
    "start": "npm run start -w packages/mcp",
    "dev": "npm run build && npm run start"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "jest": "^30.2.0",
    "shx": "^0.3.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^1.7.1",
    "typescript": "^5.8.2"
  }
}

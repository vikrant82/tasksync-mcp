{
  "name": "tasksync-mcp-http",
  "version": "1.2.0",
  "description": "TaskSync MCP server — persistent daemon feedback loop for AI coding agents",
  "license": "MIT",
  "author": "vikrant82",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vikrant82/tasksync-mcp.git"
  },
  "homepage": "https://github.com/vikrant82/tasksync-mcp",
  "bugs": {
    "url": "https://github.com/vikrant82/tasksync-mcp/issues"
  },
  "keywords": [
    "mcp",
    "tasksync",
    "feedback",
    "human-in-the-loop",
    "model-context-protocol",
    "agent",
    "daemon"
  ],
  "type": "module",
  "bin": {
    "tasksync-mcp-http": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "test": "jest --config=jest.config.cjs --coverage",
    "start": "node dist/index.js --port=3011",
    "dev": "npm run build && npm run start"
  },
  "dependencies": {
    "@grammyjs/runner": "^2.0.3",
    "@modelcontextprotocol/sdk": "^1.17.0",
    "diff": "^8.0.3",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "grammy": "^1.41.1",
    "minimatch": "^10.0.1",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/diff": "^5.0.9",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.14",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^22",
    "jest": "^30.2.0",
    "shx": "^0.3.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
